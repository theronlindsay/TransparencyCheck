{
	"name": "@transparencycheck/server",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "bun ./build",
		"fec:import-bulk": "node ./import-fec-bulk.js",
		"fec:import-bulk-metadata": "node ./import-fec-bulk.js --datasets linkage,committees,candidates",
		"fec:import-bulk-finance": "node ./import-fec-bulk.js --datasets committee-summaries,individual-contributions,committee-transactions",
		"prepare": "svelte-kit sync || echo ''",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"cron:sync-fec-bulk": "curl -sS \"http://localhost:3000/api/cron/sync-fec-bulk?secret=dev_secret\"",
		"cron:stocks": "curl -sS \"http://localhost:3000/api/cron/sync-stocks?secret=dev_secret\"",
		"cron:sync-finance": "curl -sS \"http://localhost:3000/api/cron/sync-finance?secret=dev_secret\""
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.3.3",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@types/node": "^22.19.11",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.0.0",
		"vite": "^7.0.4"
	},
	"dependencies": {
		"@better-auth/mongo-adapter": "^1.5.6",
		"@uploadthing/svelte": "^7.3.3",
		"better-auth": "^1.5.6",
		"dotenv": "^16.6.1",
		"mongodb": "^6.21.0",
		"mongoose": "^8.9.0",
		"openai": "^6.8.1",
		"stripe": "^22.0.1",
		"uploadthing": "^7.7.4"
	}
}
