// SQLite Prisma schema — mirrors the MongoDB schema but uses SQLite conventions.
// Generated client outputs to a separate directory from the Mongo client.

generator client {
  provider        = "prisma-client-js"
  output          = "../src/lib/db/generated/sqlite-client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:../db/transparency.sqlite"
}

model Bill {
  id                      String  @id
  billNumber              String
  congress                Int
  type                    String?
  introducedDate          String?
  latestAction            String?
  status                  String?
  originChamber           String?
  originChamberCode       String?
  title                   String?
  updateDate              String?
  updateDateIncludingText String?
  url                     String?
  legislationUrl          String?
  policyArea              String?
  primaryCommitteeCode    String?
  actionsCount            Int?
  actionsUrl              String?
  committeesCount         Int?
  committeesUrl           String?
  cosponsorsCount         Int?
  cosponsorsUrl           String?
  relatedBillsCount       Int?
  relatedBillsUrl         String?
  sponsors                String? // Storing JSON string
  subjectsCount           Int?
  subjectsUrl             String?
  summariesCount          Int?
  summariesUrl            String?
  textVersionsCount       Int?
  textVersionsUrl         String?
  titlesCount             Int?
  titlesUrl               String?

  @@unique([billNumber, congress])
  @@map("bills")
}

model Person {
  bioguideId String  @id
  firstName  String?
  lastName   String?
  fullName   String?
  branch     String?
  party      String?
  state      String?
  district   String?
  donors     String? // Storing JSON string
  url        String?

  @@map("people")
}

model BillPerson {
  id           Int     @id @default(autoincrement())
  billId       String
  personId     String
  relationship String?
  isByRequest  String?

  @@unique([billId, personId, relationship])
  @@map("bill_people")
}

model Committee {
  committeeCode       String  @id
  name                String?
  chamber             String?
  type                String?
  subcommitteeCode    String?
  parentCommitteeCode String?
  url                 String?

  @@map("committees")
}

model CommitteePerson {
  id            Int     @id @default(autoincrement())
  committeeCode String
  personId      String
  role          String?

  @@unique([committeeCode, personId])
  @@map("committee_people")
}

model BillCommittee {
  id            Int    @id @default(autoincrement())
  billId        String
  committeeCode String

  @@unique([billId, committeeCode])
  @@map("bill_committees")
}

model BillAction {
  id           Int     @id @default(autoincrement())
  billId       String
  actionDate   String?
  text         String?
  type         String?
  actionCode   String?
  sourceSystem String?

  @@unique([billId, actionDate, text, actionCode])
  @@index([billId, actionDate(sort: Desc)])
  @@map("bill_actions")
}

model BillTextVersion {
  id             Int     @id @default(autoincrement())
  billId         String
  type           String?
  date           String?
  formatType     String?
  url            String?
  content        String?
  contentFetched Int     @default(0)

  @@unique([billId, type, formatType])
  @@map("bill_text_versions")
}
