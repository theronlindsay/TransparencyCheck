FROM docker.io/oven/bun:1 AS build

WORKDIR /app

# Copy root and app package files
COPY package.json bun.lock ./
COPY apps/server/package.json ./apps/server/
COPY apps/client/package.json ./apps/client/

# Install all dependencies (workspace aware)
RUN bun install --frozen-lockfile

COPY . .

# Build server only
RUN bun run build:server

FROM docker.io/oven/bun:1 AS runtime

WORKDIR /app
ENV NODE_ENV=production

# Copy only server files needed at runtime
COPY --from=build /app/package.json /app/bun.lock ./
COPY --from=build /app/apps/server/package.json ./apps/server/
COPY --from=build /app/apps/client/package.json ./apps/client/
RUN bun install --production --frozen-lockfile
COPY --from=build /app/apps/server/build ./apps/server/build

# Copy startup script
COPY docker/server/start.sh ./start.sh
RUN chmod +x ./start.sh

RUN mkdir -p /app/db /app/.cache

EXPOSE 3000

CMD ["./start.sh"]
